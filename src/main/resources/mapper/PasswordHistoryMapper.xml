<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jhun.backend.mapper.PasswordHistoryMapper">

    <!--
        查询用户密码历史。
        修改密码与重置密码都要阻止复用历史密码，因此按时间倒序取出用户全部密码历史做 BCrypt 比对。
    -->
    <select id="findByUserId" resultType="com.jhun.backend.entity.PasswordHistory">
        SELECT id,
               user_id,
               password_hash,
               created_at
        FROM password_history
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>
</mapper>
